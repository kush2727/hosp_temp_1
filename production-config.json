{
  "name": "Terapia - Professional Physical Therapy Website",
  "version": "2.0.0",
  "description": "Production-ready physical therapy website with modern web standards",
  "author": "Professional Development Team",
  "license": "MIT",
  "features": {
    "responsive": true,
    "accessibility": true,
    "seo_optimized": true,
    "performance_optimized": true,
    "cross_browser_compatible": true,
    "mobile_first": true
  },
  "technologies": {
    "html5": "Latest",
    "css3": "Latest with CSS Variables",
    "javascript": "ES6+",
    "bootstrap": "5.x",
    "jquery": "3.6.x",
    "owl_carousel": "2.x",
    "wow_js": "1.x",
    "font_awesome": "5.x"
  },
  "performance": {
    "minified_css": true,
    "minified_js": true,
    "image_optimization": true,
    "lazy_loading": true,
    "caching_headers": true,
    "gzip_compression": true
  },
  "seo": {
    "meta_tags": true,
    "structured_data": true,
    "open_graph": true,
    "twitter_cards": true,
    "sitemap": true,
    "robots_txt": true
  },
  "accessibility": {
    "wcag_2.1_aa": true,
    "aria_labels": true,
    "keyboard_navigation": true,
    "screen_reader_support": true,
    "focus_indicators": true,
    "color_contrast": true
  },
  "browser_support": {
    "chrome": "90+",
    "firefox": "88+",
    "safari": "14+",
    "edge": "90+",
    "mobile_safari": "14+",
    "chrome_mobile": "90+"
  },
  "deployment": {
    "environment": "production",
    "cdn_ready": true,
    "ssl_required": true,
    "compression": "gzip",
    "caching": "1 year for assets, 1 hour for HTML"
  }
}